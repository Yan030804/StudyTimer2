<Window x:Class="StudyTimer.App.SessionEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="学习明细" Width="430" Height="395" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="记录日期" Foreground="{StaticResource MutedTextBrush}" />
            <TextBlock x:Name="DateText" FontSize="20" FontWeight="SemiBold" Margin="0,6,0,0" />
        </StackPanel>
        <StackPanel Grid.Row="2">
            <TextBlock Text="学习科目" Margin="0,0,0,6" />
            <ComboBox x:Name="SubjectComboBox" DisplayMemberPath="Name" />
        </StackPanel>
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="18"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="开始时间" Margin="0,0,0,6" />
                <TextBox x:Name="StartTextBox" ToolTip="例如 08:30:00" />
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="结束时间" Margin="0,0,0,6" />
                <TextBox x:Name="EndTextBox" ToolTip="例如 10:00:00；24:00:00 表示次日零点" />
            </StackPanel>
        </Grid>
        <TextBlock Grid.Row="6" Text="时间格式为 HH:mm:ss；结束时间可填写 24:00:00。"
                   Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="取消" IsCancel="True" />
            <Button Content="保存" Click="Save_Click" Style="{StaticResource PrimaryButtonStyle}" Margin="0" />
        </StackPanel>
    </Grid>
</Window>
