<Window x:Class="StudyTimer.App.SubjectManagementDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="管理科目" Width="650" Height="510" MinWidth="580" MinHeight="440"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Grid Margin="24">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="16"/><RowDefinition Height="*"/><RowDefinition Height="16"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="科目管理" FontSize="22" FontWeight="SemiBold" />
                <TextBlock Text="归档科目会保留历史数据，但不再出现在新计时选择中。" Foreground="{StaticResource MutedTextBrush}" Margin="0,5,0,0" />
            </StackPanel>
            <Button Grid.Column="1" Content="新增科目" Click="Add_Click" Style="{StaticResource PrimaryButtonStyle}" Margin="0" />
        </Grid>
        <DataGrid x:Name="SubjectGrid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                  SelectionMode="Single" RowHeight="48" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EAECF0"
                  BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" SelectionChanged="SubjectGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="颜色" Width="70">
                    <DataGridTemplateColumn.CellTemplate><DataTemplate><Border Width="20" Height="20" CornerRadius="10" Background="{Binding Color}" HorizontalAlignment="Center"/></DataTemplate></DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="科目名称" Binding="{Binding Name}" Width="*" />
                <DataGridTemplateColumn Header="状态" Width="120">
                    <DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding StatusText}" /></DataTemplate></DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <Button Content="关闭" IsCancel="True" HorizontalAlignment="Left" Margin="0" />
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="EditButton" Content="修改" Click="Edit_Click" IsEnabled="False" />
                <Button x:Name="ArchiveButton" Content="归档" Click="Archive_Click" IsEnabled="False" Margin="0" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
