<Window x:Class="StudyTimer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:StudyTimer.App.Controls"
        Title="学习计时器" Icon="Assets/study-timer.ico"
        Width="1180" Height="800" MinWidth="960" MinHeight="680"
        WindowStartupLocation="CenterScreen" Closing="Window_Closing">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="学习计时器" FontSize="28" FontWeight="SemiBold" />
                <TextBlock Text="让每一次专注都清楚可见" Foreground="{StaticResource MutedTextBrush}" Margin="0,6,0,0" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="打开数据文件夹" Command="{Binding OpenDataFolderCommand}" />
                <Button Content="紧凑模式" Command="{Binding CompactCommand}" Margin="0" />
            </StackPanel>
        </Grid>

        <TabControl Grid.Row="2" Background="Transparent" BorderThickness="0">
            <TabItem Header="计时">
                <Grid Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="{StaticResource CardBrush}" CornerRadius="16" Padding="42"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="本次学习" Foreground="{StaticResource MutedTextBrush}" FontSize="16" HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding TimerText}" FontFamily="Consolas" FontSize="68" FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" Margin="0,18,0,8" />
                            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource MutedTextBrush}"
                                       FontWeight="SemiBold" HorizontalAlignment="Center" />

                            <Grid Margin="0,28,0,0" HorizontalAlignment="Center" Width="390">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="学习科目" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,7" />
                                    <ComboBox ItemsSource="{Binding ActiveSubjects}" SelectedItem="{Binding SelectedSubject}"
                                              DisplayMemberPath="Name" IsEnabled="{Binding CanSelectSubject}" />
                                </StackPanel>
                                <Button Grid.Column="1" Content="管理科目" Command="{Binding ManageSubjectsCommand}"
                                        VerticalAlignment="Bottom" Margin="10,0,0,0" />
                            </Grid>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,28,0,0">
                                <Button Content="{Binding ToggleText}" Command="{Binding ToggleTimerCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}" MinWidth="130" />
                                <Button Content="停止并保存" Command="{Binding StopTimerCommand}" MinWidth="130" Margin="0" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="2">
                        <Border Style="{StaticResource MetricCardStyle}">
                            <StackPanel>
                                <TextBlock Text="今日累计" Foreground="{StaticResource MutedTextBrush}" />
                                <TextBlock Text="{Binding TodayText}" FontSize="30" FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryBrush}" Margin="0,10,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Background="#EEF2FF" CornerRadius="16" Padding="26" Margin="0,18,0,0">
                            <StackPanel>
                                <TextBlock Text="当前科目" Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding CurrentSubjectName}" FontSize="22" FontWeight="SemiBold" Margin="0,8,0,0" />
                                <TextBlock Text="计时开始后科目会锁定，停止保存后可重新选择。"
                                           TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}"
                                           Margin="0,10,0,0" LineHeight="22" />
                            </StackPanel>
                        </Border>
                        <Border Background="#F8FAFC" CornerRadius="16" Padding="26" Margin="0,18,0,0">
                            <StackPanel>
                                <TextBlock Text="安全保存" FontWeight="SemiBold" />
                                <TextBlock Text="停止后写入当天文本文件；计时中每 5 秒保存恢复状态。"
                                           TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}"
                                           Margin="0,8,0,0" LineHeight="22" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="统计">
                <Grid Margin="0,18,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="SevenDaysButton" Content="7天" Tag="SevenDays" GroupName="StatisticsPeriod"
                                         IsChecked="True" Checked="StatisticsPeriod_Checked" Style="{StaticResource SegmentRadioStyle}" />
                            <RadioButton x:Name="MonthButton" Content="本月" Tag="Month" GroupName="StatisticsPeriod"
                                         Checked="StatisticsPeriod_Checked" Style="{StaticResource SegmentRadioStyle}" />
                            <RadioButton x:Name="YearButton" Content="本年" Tag="Year" GroupName="StatisticsPeriod"
                                         Checked="StatisticsPeriod_Checked" Style="{StaticResource SegmentRadioStyle}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="上一期" Click="StatisticsPrevious_Click" />
                            <Button Content="回到今天" Click="StatisticsToday_Click" />
                            <DatePicker SelectedDate="{Binding StatisticsAnchorDate, Mode=TwoWay}" Width="145" Height="40" Margin="0,0,10,0" />
                            <Button Content="下一期" Click="StatisticsNext_Click" IsEnabled="{Binding CanNavigateStatisticsNext}" Margin="0" />
                        </StackPanel>
                        <StackPanel Grid.Column="3" Orientation="Horizontal">
                            <ComboBox ItemsSource="{Binding StatisticsSubjectOptions}" SelectedItem="{Binding SelectedStatisticsSubject}"
                                      DisplayMemberPath="Name" Width="150" Margin="0,0,10,0" />
                            <Button Content="导出当前区间" Click="ExportCurrent_Click" />
                            <Button Content="导出全部" Click="ExportAll_Click" Margin="0" />
                        </StackPanel>
                    </Grid>

                    <UniformGrid Grid.Row="2" Columns="4">
                        <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,10,0">
                            <StackPanel><TextBlock Text="总时长" Foreground="{StaticResource MutedTextBrush}"/><TextBlock Text="{Binding StatisticsTotalText}" FontSize="22" FontWeight="SemiBold" Margin="0,8,0,0"/></StackPanel>
                        </Border>
                        <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,10,0">
                            <StackPanel><TextBlock Text="日均时长" Foreground="{StaticResource MutedTextBrush}"/><TextBlock Text="{Binding StatisticsAverageText}" FontSize="22" FontWeight="SemiBold" Margin="0,8,0,0"/></StackPanel>
                        </Border>
                        <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,10,0">
                            <StackPanel><TextBlock Text="最长学习日" Foreground="{StaticResource MutedTextBrush}"/><TextBlock Text="{Binding StatisticsLongestDayText}" FontSize="18" FontWeight="SemiBold" Margin="0,8,0,0"/></StackPanel>
                        </Border>
                        <Border Style="{StaticResource MetricCardStyle}">
                            <StackPanel><TextBlock Text="最长连续" Foreground="{StaticResource MutedTextBrush}"/><TextBlock Text="{Binding StatisticsStreakText}" FontSize="22" FontWeight="SemiBold" Margin="0,8,0,0"/></StackPanel>
                        </Border>
                    </UniformGrid>

                    <Border Grid.Row="4" Background="{StaticResource CardBrush}" CornerRadius="16" Padding="24"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding StatisticsTitle}" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock Text="柱形高度表示学习时长，悬停可查看精确数据。"
                                           Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" />
                            </StackPanel>
                            <controls:BarChart Grid.Row="1" Margin="0,12,0,0" ItemsSource="{Binding StatisticsPoints}"
                                               AutomationProperties.Name="{Binding StatisticsAccessibleSummary}" />
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="历史记录">
                <Border Background="{StaticResource CardBrush}" CornerRadius="16" Padding="24"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,18,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="上一天" Click="HistoryPrevious_Click" />
                                <DatePicker SelectedDate="{Binding HistoryDate, Mode=TwoWay}" Width="150" Height="40" Margin="0,0,10,0" />
                                <Button Content="今天" Click="HistoryToday_Click" />
                                <Button Content="下一天" Click="HistoryNext_Click" IsEnabled="{Binding CanMoveHistoryNext}" Margin="0" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <ComboBox ItemsSource="{Binding HistorySubjectOptions}" SelectedItem="{Binding SelectedHistorySubject}"
                                          DisplayMemberPath="Name" Width="165" Margin="0,0,10,0" />
                                <Button Content="新增记录" Click="AddSession_Click" Style="{StaticResource PrimaryButtonStyle}" Margin="0" />
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="14"/><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Border Background="#F8FAFC" CornerRadius="10" Padding="16">
                                <StackPanel><TextBlock Text="当日总时长" Foreground="{StaticResource MutedTextBrush}"/><TextBlock Text="{Binding HistoryTotalText}" FontSize="22" FontWeight="SemiBold" Margin="0,6,0,0"/></StackPanel>
                            </Border>
                            <Border Grid.Column="2" Background="#F8FAFC" CornerRadius="10" Padding="16">
                                <StackPanel><TextBlock Text="学习次数" Foreground="{StaticResource MutedTextBrush}"/><TextBlock Text="{Binding HistoryCountText}" FontSize="22" FontWeight="SemiBold" Margin="0,6,0,0"/></StackPanel>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="4">
                            <DataGrid x:Name="HistoryGrid" ItemsSource="{Binding HistorySessions}"
                                      AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                                      SelectionMode="Single" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="#EAECF0" VerticalGridLinesBrush="Transparent"
                                      BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                      AlternatingRowBackground="#F8FAFC" RowBackground="White" RowHeight="50"
                                      SelectionChanged="HistoryGrid_SelectionChanged" MouseDoubleClick="HistoryGrid_MouseDoubleClick">
                                <DataGrid.Resources>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#F2F4F7"/><Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Padding" Value="14,10"/><Setter Property="BorderThickness" Value="0"/>
                                    </Style>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Padding" Value="14,8"/><Setter Property="BorderThickness" Value="0"/>
                                    </Style>
                                </DataGrid.Resources>
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="科目" Width="1.3*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border Background="{Binding SubjectColor}" CornerRadius="10" Padding="10,4" HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding SubjectName}" Foreground="White" FontWeight="SemiBold" />
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="开始时间" Binding="{Binding StartText}" Width="*" />
                                    <DataGridTextColumn Header="结束时间" Binding="{Binding EndText}" Width="*" />
                                    <DataGridTextColumn Header="学习时长" Binding="{Binding DurationText}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <Border Background="White" Visibility="{Binding HasNoHistoryRecords, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="当天还没有学习记录" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                    <TextBlock Text="可以开始一次计时，或手动补充历史记录。" Foreground="{StaticResource MutedTextBrush}" Margin="0,8,0,18" />
                                    <Button Content="新增记录" Click="AddSession_Click" Style="{StaticResource PrimaryButtonStyle}" Margin="0" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="EditHistoryButton" Content="修改所选" Click="EditSession_Click" IsEnabled="False" />
                            <Button x:Name="DeleteHistoryButton" Content="删除所选" Click="DeleteSession_Click" IsEnabled="False" Margin="0" />
                        </StackPanel>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
