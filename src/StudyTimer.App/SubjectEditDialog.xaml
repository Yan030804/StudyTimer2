<Window x:Class="StudyTimer.App.SubjectEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="科目" Width="420" Height="330" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/><RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="科目名称" Margin="0,0,0,6" />
            <TextBox x:Name="NameTextBox" MaxLength="24" />
        </StackPanel>
        <StackPanel Grid.Row="2">
            <TextBlock Text="标签颜色" Margin="0,0,0,6" />
            <ComboBox x:Name="ColorComboBox">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="18" Height="18" CornerRadius="9" Background="{Binding}" Margin="0,0,10,0" />
                            <TextBlock Text="{Binding}" VerticalAlignment="Center" />
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </StackPanel>
        <TextBlock Grid.Row="4" Text="名称不能包含竖线或换行；同名科目不能重复。"
                   Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="取消" IsCancel="True" />
            <Button Content="保存" Click="Save_Click" Style="{StaticResource PrimaryButtonStyle}" Margin="0" />
        </StackPanel>
    </Grid>
</Window>
