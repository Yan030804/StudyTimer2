<Window x:Class="StudyTimer.App.CompactWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="学习计时器 - 紧凑模式" Icon="Assets/study-timer.ico" Width="404" Height="150"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="True" WindowStartupLocation="Manual"
        Loaded="Window_Loaded" LocationChanged="Window_LocationChanged" Closing="Window_Closing" Closed="Window_Closed">
    <Border Background="#FCFFFFFF" CornerRadius="16" BorderBrush="#D0D5DD" BorderThickness="1"
            Padding="17" MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <Border Background="{Binding CurrentSubjectBackground}" CornerRadius="8" Padding="8,2" Margin="0,0,8,0">
                        <TextBlock Text="{Binding CurrentSubjectName}" Foreground="{Binding CurrentSubjectColor}"
                                   FontSize="11" FontWeight="SemiBold" />
                    </Border>
                    <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource MutedTextBrush}" FontSize="11" VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Text="{Binding TimerText}" FontFamily="Consolas" FontSize="30" FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryBrush}" Margin="0,5,0,0" />
            </StackPanel>
            <StackPanel Grid.Column="1" Width="92" Margin="8,0,8,0" VerticalAlignment="Center">
                <Button Content="{Binding ToggleText}" Command="{Binding ToggleTimerCommand}"
                        Style="{StaticResource PrimaryButtonStyle}" Width="92" Height="54" Margin="0,0,0,8" Padding="8,6" />
                <Button x:Name="TopmostButton" Content="置顶" Click="Topmost_Click"
                        Width="92" Height="40" Margin="0" Padding="8,6" />
            </StackPanel>
            <Button Grid.Column="2" Content="展开" Click="Expand_Click" Width="62" Height="102" Margin="0" Padding="8,6" />
        </Grid>
    </Border>
</Window>
