<Window x:Class="StudyTimer.App.CompactWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="学习计时器 - 紧凑模式" Icon="Assets/study-timer.ico" Width="330" Height="116"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="True" WindowStartupLocation="CenterScreen" Closing="Window_Closing">
    <Border Background="#F9FFFFFF" CornerRadius="16" BorderBrush="#D0D5DD" BorderThickness="1"
            Padding="18" MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{Binding TimerText}" FontFamily="Consolas" FontSize="30" FontWeight="SemiBold" />
                <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="1,3,0,0" />
            </StackPanel>
            <Button Grid.Column="1" Content="{Binding ToggleText}" Command="{Binding ToggleTimerCommand}"
                    Style="{StaticResource PrimaryButtonStyle}" MinWidth="72" Margin="12,0,8,0" />
            <Button Grid.Column="2" Content="展开" Click="Expand_Click" MinWidth="60" Margin="0" />
        </Grid>
    </Border>
</Window>
