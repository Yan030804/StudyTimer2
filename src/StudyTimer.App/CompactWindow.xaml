<Window x:Class="StudyTimer.App.CompactWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="学习计时器 - 紧凑模式" Icon="Assets/study-timer.ico" Width="430" Height="126"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="True" WindowStartupLocation="Manual"
        Loaded="Window_Loaded" LocationChanged="Window_LocationChanged" Closing="Window_Closing" Closed="Window_Closed">
    <Border Background="#FCFFFFFF" CornerRadius="16" BorderBrush="#D0D5DD" BorderThickness="1"
            Padding="17" MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <Border Background="{StaticResource PrimaryBrush}" CornerRadius="8" Padding="8,2" Margin="0,0,8,0">
                        <TextBlock Text="{Binding CurrentSubjectName}" Foreground="White" FontSize="11" FontWeight="SemiBold" />
                    </Border>
                    <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource MutedTextBrush}" FontSize="11" VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Text="{Binding TimerText}" FontFamily="Consolas" FontSize="30" FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryBrush}" Margin="0,5,0,0" />
            </StackPanel>
            <Button Grid.Column="1" Content="{Binding ToggleText}" Command="{Binding ToggleTimerCommand}"
                    Style="{StaticResource PrimaryButtonStyle}" MinWidth="68" Margin="12,0,8,0" />
            <Button x:Name="TopmostButton" Grid.Column="2" Content="置顶" Click="Topmost_Click" MinWidth="58" Margin="0,0,8,0" />
            <Button Grid.Column="3" Content="展开" Click="Expand_Click" MinWidth="58" Margin="0" />
        </Grid>
    </Border>
</Window>
